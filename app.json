{
  "expo": {
    "name": "GCash POS",
    "slug": "gcash-pos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "gcash-pos",
    "splash": {
      "backgroundColor": "#0078D4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gcash.pos"
    },
    "android": {
      "package": "com.gcash.pos",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0078D4",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "INTERNET",
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-av",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "extraProguardRules": "-keep class expo.modules.** { *; }\n-keep class com.facebook.hermes.** { *; }\n-keep class com.facebook.jni.** { *; }"
          }
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0d810cfc-db6d-4805-a5d1-6e0bf36988e0"
      }
    },
    "owner": "chmoralla-codes-team"
  }
}
